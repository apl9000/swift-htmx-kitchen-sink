<!doctype html>
<html lang="en">
    <head>
      <meta charset="utf-8">
      <title>#(title)</title>
      <link href="/style.css" rel="stylesheet">
    </head>
    <body>
      <h1>#(title)</h1>
      <p>Welcome to the Leaf template engine!</p>
      <p>Leaf is a powerful templating engine for Swift.</p>
      <p>Made easy with tailwind CSS.</p>
      #import("body")
    </body>
    <script src="http://localhost:35729/livereload.js?snipver=1"></script>
</html>